# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# === Backend ===
DATABASE_URL=postgresql+asyncpg://...   # Supabase connection string
DIRECT_DATABASE_URL=postgresql://...    # for migrations (no pooler)
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                         # empty for local
OLLAMA_BASE_URL=http://localhost:11434

# === Router: Qwen2.5-7B via local Ollama ===
ROUTER_BASE_URL=http://localhost:11434/v1
ROUTER_API_KEY=ollama
ROUTER_MODEL_NAME=qwen2.5:7b

# === Generator: GLM-4.5-Air via OpenRouter free tier ===
# Sign up at https://openrouter.ai (free, no credit card needed)
# Free limits: ~20 req/min, ~200 messages/day
GENERATOR_BASE_URL=https://openrouter.ai/api/v1
GENERATOR_API_KEY=<your_openrouter_key>
GENERATOR_MODEL_NAME=z-ai/glm-4.5-air:free

# === Verifier: Llama-3.3-70B via OpenRouter free tier ===
VERIFIER_BASE_URL=https://openrouter.ai/api/v1
VERIFIER_API_KEY=<your_openrouter_key>
VERIFIER_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free

# === Embeddings: BGE-M3 via local Ollama ===
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL_NAME=bge-m3:latest

# === External APIs ===
RXNAV_BASE_URL=https://rxnav.nlm.nih.gov/REST
OPENFDA_BASE_URL=https://api.fda.gov

# === Google Calendar ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# === Observability ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# === Storage ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents
